# ===== Application =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ===== Database =====
# SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///./data/pr_review.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/pr_review

# ===== Redis (optional; falls back to in-memory when unset) =====
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# ===== API Auth =====
# Bearer token required by management endpoints (/api/v1/reviews*).
# Fail-closed: if unset and api.require_api_key (see config/default.yaml, not an env
# var) is true, those endpoints reject all requests with 503.
API_KEY=

# ===== GitHub App =====
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./config/github-app-private-key.pem
# Or inline (PEM). Do NOT commit.
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Optional: use a classic PAT instead of a GitHub App
GITHUB_TOKEN=

# ===== LLM =====
# OpenAI-compatible endpoint. Dev default: SiliconFlow.
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3.6-27B
LLM_TIMEOUT_SECONDS=180
# Set to "mock" to run without real LLM calls
LLM_MODE=openai
# Max completion tokens. Reasoning models spend tokens "thinking" before the
# answer, so leave ample room (thinking + output share this budget). Default 8192.
LLM_MAX_TOKENS=16384
# OpenAI alternative:
#   LLM_API_BASE=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_MAX_TOKENS=4096

# ===== Sandbox =====
SANDBOX_ENABLED=true
SANDBOX_IMAGE=pr-review-sandbox:latest
SANDBOX_WORKSPACE=/workspace
